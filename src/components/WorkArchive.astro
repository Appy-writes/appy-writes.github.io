---
import type { CollectionEntry } from "astro:content";
import { nicheDefinitions } from "../data/site";
import WorkCard from "./WorkCard.astro";

type Props = {
  entries: CollectionEntry<"work">[];
};

const { entries } = Astro.props;
const workTypes = [...new Set(entries.map((entry) => entry.data.workType))].sort();
const nicheLabelMap = Object.fromEntries(nicheDefinitions.map((niche) => [niche.slug, niche.label]));
const searchSuggestions = Array.from(new Set(
  entries.flatMap((entry) => [
    entry.data.title,
    ...entry.data.tags,
    entry.data.client,
    entry.data.publication
  ].filter(Boolean) as string[])
)).sort((a, b) => a.localeCompare(b));
---

<section class="space-y-8">
  <div class="card-surface rounded-[1.8rem] p-6 md:p-8">
    <div class="grid gap-5 lg:grid-cols-[1.8fr_1fr_1fr]">
      <label class="flex flex-col gap-2 text-sm font-semibold text-[var(--ink)]">
        Search
        <input
          class="rounded-2xl border border-[var(--line)] bg-[var(--paper-strong)] px-4 py-3 text-sm font-medium text-[var(--ink)] outline-none transition placeholder:text-[var(--muted)] focus:border-[rgba(163,90,61,0.5)]"
          type="search"
          name="search"
          placeholder="Search titles, excerpts, or tags"
          data-filter-search
          list="work-search-suggestions"
          autocomplete="off"
        />
        <datalist id="work-search-suggestions" data-search-suggestions>
          {searchSuggestions.slice(0, 3).map((suggestion) => (
            <option value={suggestion}></option>
          ))}
        </datalist>
      </label>

      <label class="flex flex-col gap-2 text-sm font-semibold text-[var(--ink)]">
        Niche
        <select class="rounded-2xl border border-[var(--line)] bg-[var(--paper-strong)] px-4 py-3 text-sm font-medium text-[var(--ink)]" data-filter-niche>
          <option value="">All niches</option>
          {nicheDefinitions.map((niche) => (
            <option value={niche.slug}>{niche.label}</option>
          ))}
        </select>
      </label>

      <label class="flex flex-col gap-2 text-sm font-semibold text-[var(--ink)]">
        Type
        <select class="rounded-2xl border border-[var(--line)] bg-[var(--paper-strong)] px-4 py-3 text-sm font-medium text-[var(--ink)]" data-filter-type>
          <option value="">All types</option>
          {workTypes.map((workType) => (
            <option value={workType}>{workType.replaceAll("-", " ")}</option>
          ))}
        </select>
      </label>
    </div>

    <div class="mt-5 flex flex-wrap gap-3 text-sm" data-active-filters></div>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-archive-grid>
    {entries.map((entry) => (
      <WorkCard entry={entry} />
    ))}
  </div>

  <p class="hidden text-sm font-semibold text-[var(--muted)]" data-empty-state>
    No samples match the current filters yet. Try a broader niche, format, or search term.
  </p>

</section>

<script is:inline define:vars={{ nicheLabelMap }}>
  /** @type {HTMLInputElement | null} */
  const searchInput = document.querySelector("[data-filter-search]");
  /** @type {HTMLDataListElement | null} */
  const suggestionsList = document.querySelector("[data-search-suggestions]");
  /** @type {HTMLSelectElement | null} */
  const nicheSelect = document.querySelector("[data-filter-niche]");
  /** @type {HTMLSelectElement | null} */
  const typeSelect = document.querySelector("[data-filter-type]");
  /** @type {HTMLElement[]} */
  const cards = Array.from(document.querySelectorAll("[data-card]"));
  /** @type {HTMLElement | null} */
  const grid = document.querySelector("[data-archive-grid]");
  /** @type {HTMLElement | null} */
  const emptyState = document.querySelector("[data-empty-state]");
  /** @type {HTMLElement | null} */
  const activeFilters = document.querySelector("[data-active-filters]");
  const suggestionPool = /** @type {string[]} */ (JSON.parse(`${
    JSON.stringify(searchSuggestions)
  }`));

  /**
   * @param {string} value
   */
  function updateSuggestions(value) {
    if (!suggestionsList) return;

    const query = value.trim().toLowerCase();
    const matches = suggestionPool
      .filter((item) => {
        const normalized = item.toLowerCase();
        return query ? normalized.includes(query) : true;
      })
      .sort((a, b) => {
        const aLower = a.toLowerCase();
        const bLower = b.toLowerCase();
        const aStarts = query ? aLower.startsWith(query) : false;
        const bStarts = query ? bLower.startsWith(query) : false;
        if (aStarts !== bStarts) return aStarts ? -1 : 1;
        return a.length - b.length || a.localeCompare(b);
      })
      .slice(0, 3);

    suggestionsList.innerHTML = matches
      .map((item) => `<option value="${item.replace(/"/g, "&quot;")}"></option>`)
      .join("");
  }

  /**
   * @param {Record<string, string>} filters
   */
  function renderActiveFilters(filters) {
    if (!activeFilters) return;
    const items = Object.values(filters).filter(Boolean);
    activeFilters.innerHTML = items.length
      ? items.map((item) => `<span class="pill">${item}</span>`).join("")
      : '<span class="text-sm text-[var(--muted)]">New portfolio samples will appear here once they are added.</span>';
  }

  function applyFilters() {
    const searchValue = (searchInput?.value || "").trim().toLowerCase();
    const nicheValue = nicheSelect?.value || "";
    const typeValue = typeSelect?.value || "";

    const visibleCards = cards.filter((card) => {
      const searchHaystack = `${card.dataset.title || ""} ${card.dataset.excerpt || ""} ${card.dataset.niches || ""}`.toLowerCase();
      const matchesSearch = !searchValue || searchHaystack.includes(searchValue);
      const matchesNiche = !nicheValue || (card.dataset.niches || "").split("|").includes(nicheValue);
      const matchesType = !typeValue || card.dataset.workType === typeValue;
      const show = matchesSearch && matchesNiche && matchesType;
      card.classList.toggle("hidden", !show);
      return show;
    });

    visibleCards.forEach((card) => grid?.appendChild(card));

    renderActiveFilters({
      search: searchValue ? `Search: ${searchValue}` : "",
      niche: nicheValue ? `Niche: ${nicheLabelMap[nicheValue] ?? nicheValue}` : "",
      type: typeValue ? `Type: ${typeValue.replaceAll("-", " ")}` : ""
    });

    emptyState?.classList.toggle("hidden", visibleCards.length !== 0);
  }

  [searchInput, nicheSelect, typeSelect].forEach((control) => {
    control?.addEventListener("input", applyFilters);
    control?.addEventListener("change", applyFilters);
  });

  searchInput?.addEventListener("input", () => updateSuggestions(searchInput.value));

  const params = new URLSearchParams(window.location.search);
  if (params.get("niche") && nicheSelect) nicheSelect.value = params.get("niche");
  if (params.get("type") && typeSelect) typeSelect.value = params.get("type");
  updateSuggestions(searchInput?.value || "");
  applyFilters();
</script>
