---
import { siteData } from "../data/site";
import { withBase } from "../utils/content";

const links = [
  { href: withBase("/"), label: "Home", accentStart: "#8f4c31", accentEnd: "#c49a54" },
  { href: withBase("/work/"), label: "Work", accentStart: "#32463c", accentEnd: "#8f4c31" },
  { href: withBase("/services/"), label: "Services", accentStart: "#c49a54", accentEnd: "#8f4c31" },
  { href: withBase("/about/"), label: "About", accentStart: "#7a5d50", accentEnd: "#32463c" },
  { href: withBase("/contact/"), label: "Contact", accentStart: "#8f4c31", accentEnd: "#32463c" }
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40">
  <div class="page-shell flex items-center justify-between gap-6 py-4">
    <a href={withBase("/")} class="header-brand-block flex flex-col">
      <span class="font-['Fraunces'] text-xl font-semibold tracking-[-0.03em]">{siteData.name}</span>
      <span class="text-xs uppercase tracking-[0.18em] text-[var(--muted)]">{siteData.title}</span>
    </a>

    <nav aria-label="Primary" class="hidden md:flex">
      <ul class="animated-nav">
        {links.map((link) => {
          const isActive = currentPath === new URL(link.href, Astro.url).pathname;
          return (
            <li
              class:list={["animated-nav-item", isActive && "is-active"]}
              style={`--nav-start: ${link.accentStart}; --nav-end: ${link.accentEnd};`}
            >
              <a href={link.href} class="animated-nav-link" aria-current={isActive ? "page" : undefined}>
                <span class="nav-initial" aria-hidden="true">{link.label.charAt(0)}</span>
                <span class="title">{link.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <button
        type="button"
        class="theme-toggle-button"
        data-theme-toggle
        aria-label="Toggle light and dark mode"
        title="Toggle light and dark mode"
      >
        <span class="theme-toggle-icon theme-toggle-sun" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4.2"></circle>
            <path d="M12 2.5v2.4"></path>
            <path d="M12 19.1v2.4"></path>
            <path d="M4.9 4.9l1.7 1.7"></path>
            <path d="M17.4 17.4l1.7 1.7"></path>
            <path d="M2.5 12h2.4"></path>
            <path d="M19.1 12h2.4"></path>
            <path d="M4.9 19.1l1.7-1.7"></path>
            <path d="M17.4 6.6l1.7-1.7"></path>
          </svg>
        </span>
        <span class="theme-toggle-icon theme-toggle-moon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.2 14.1A8.7 8.7 0 0 1 9.9 3.8a.7.7 0 0 0-.9-.9A9.7 9.7 0 1 0 21.1 15a.7.7 0 0 0-.9-.9Z"></path>
          </svg>
        </span>
      </button>
      <a href={withBase("/contact/")} class="button-primary hidden md:inline-flex">Start a Project</a>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector("[data-theme-toggle]");
  const root = document.documentElement;

  toggle?.addEventListener("click", () => {
    const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = nextTheme;
    localStorage.setItem("theme", nextTheme);
  });
</script>
