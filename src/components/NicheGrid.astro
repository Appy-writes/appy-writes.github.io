---
import type { CollectionEntry } from "astro:content";
import { nicheDefinitions } from "../data/site";
import { resolveAssetUrl, withBase } from "../utils/content";

type Props = {
  entries: CollectionEntry<"work">[];
  activeSlug?: string;
};

const { activeSlug = "" } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
  {nicheDefinitions.map((card) => (
    <a
      href={`${withBase("/work/")}?niche=${card.slug}`}
      class:list={[
        "card-surface niche-card group rounded-[1.6rem] p-6 transition-all duration-300 hover:-translate-y-1",
        activeSlug === card.slug && "is-active"
      ]}
      data-niche-card={card.slug}
    >
      <div class="overflow-hidden rounded-[1.2rem] border border-[var(--line)] bg-[var(--paper-strong)]">
        <img src={resolveAssetUrl(card.image)} alt="" class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" />
      </div>
      <div class="mt-5 flex items-center justify-between gap-4">
        <p class="font-['Fraunces'] text-2xl tracking-[-0.03em]">{card.label}</p>
      </div>
      <p class="mt-3 text-sm text-[var(--muted)]">{card.summary}</p>
      <span class="horizon-sheen niche-browse-button mt-5 inline-flex items-center gap-2 rounded-full border border-[rgba(163,90,61,0.25)] bg-[rgba(163,90,61,0.08)] px-4 py-2 text-sm font-semibold text-[var(--accent)] transition-all duration-300 group-hover:translate-x-1 group-hover:border-[rgba(163,90,61,0.45)] group-hover:text-[var(--ink)]">
        Browse this niche
        <span class="inline-block animate-[nudge_1.2s_ease-in-out_infinite]">→</span>
      </span>
    </a>
  ))}
</div>
