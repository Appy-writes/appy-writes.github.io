---
import type { CollectionEntry } from "astro:content";
import { statusLabels, withBase, workTypeLabels } from "../utils/content";

type Props = {
  entry: CollectionEntry<"work">;
  compact?: boolean;
};

const { entry, compact = false } = Astro.props;
const metaLine = [entry.data.client, entry.data.publication].filter(Boolean).join(" / ");
const similarHref = `${withBase("/work/")}?niche=${entry.data.niche[0] ?? ""}`;
const sourceLabel = entry.data.externalUrl ? "Open source link" : entry.data.proofLabel || statusLabels[entry.data.status];
---

<article
  class="card-surface flex h-full flex-col overflow-hidden rounded-[1.7rem]"
  data-card
  data-title={entry.data.title.toLowerCase()}
  data-excerpt={entry.data.excerpt.toLowerCase()}
  data-niches={entry.data.niche.join("|")}
  data-format={entry.data.format}
  data-work-type={entry.data.workType}
  data-featured={entry.data.featured ? "true" : "false"}
  data-date={entry.data.date ?? ""}
>
  {entry.data.coverImage ? (
    <div class="aspect-[16/10] overflow-hidden border-b border-[var(--line)] bg-[var(--paper-strong)]">
      <img src={withBase(entry.data.coverImage)} alt="" class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02]" loading="lazy" />
    </div>
  ) : (
    <div class="relative flex aspect-[16/10] items-end overflow-hidden border-b border-[var(--line)] bg-[linear-gradient(135deg,rgba(163,90,61,0.18),rgba(50,70,60,0.18))] p-5">
      <div class="absolute inset-0 opacity-60">
        <div class="h-full w-full bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.8),transparent_38%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.35),transparent_34%)]"></div>
      </div>
      <div class="relative">
        <span class="pill bg-[var(--paper-strong)] text-[var(--ink)]">{entry.data.format}</span>
      </div>
    </div>
  )}

  <div class="flex h-full flex-col p-6">
    <div class="flex flex-wrap gap-2">
      {entry.data.niche.slice(0, 2).map((tag) => (
        <span class="pill">{tag.replaceAll("-", " ")}</span>
      ))}
    </div>

    <h3 class="mt-4 text-2xl tracking-[-0.03em]">{entry.data.title}</h3>
    <p class="mt-3 text-sm text-[var(--muted)]">{entry.data.excerpt}</p>

    {!compact && (
      <div class="mt-5 space-y-2 text-sm text-[var(--muted)]">
        <p><strong class="text-[var(--ink)]">Type:</strong> {workTypeLabels[entry.data.workType]}</p>
        {metaLine && <p><strong class="text-[var(--ink)]">Client / publication:</strong> {metaLine}</p>}
        {entry.data.date && <p><strong class="text-[var(--ink)]">Date:</strong> {entry.data.date}</p>}
      </div>
    )}

    <div class="mt-6 flex flex-wrap gap-3">
      {entry.data.externalUrl ? (
        <a class="button-primary" href={entry.data.externalUrl} target="_blank" rel="noreferrer">{sourceLabel}</a>
      ) : (
        <span class="button-secondary cursor-default">{sourceLabel}</span>
      )}
      <a class="button-secondary" href={similarHref}>Similar Work</a>
    </div>
  </div>
</article>
