---
import { getCollection } from "astro:content";
import MailMotion from "../components/MailMotion.astro";
import ServiceSelector from "../components/ServiceSelector.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/content";

const services = await getCollection("services");
---

<BaseLayout
  title="Services"
  description="Conversion-focused content services from Atrayee Banerjee, including SEO blogs, thought leadership, website copy, newsletters, social content, and content strategy support."
>
  <section class="py-8 md:py-10">
    <div class="page-shell space-y-3">
      <p class="eyebrow">Services</p>
      <h1 class="max-w-3xl text-3xl tracking-[-0.04em] md:text-4xl">Useful writing support for teams that need clarity, consistency, and stronger content systems.</h1>
      <p class="max-w-2xl text-sm text-[var(--muted)]">
        Choose the kind of content support you need, and the page will narrow the offer into something easier to scan, compare, and act on.
      </p>
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="page-shell">
      <ServiceSelector services={services} />
    </div>
  </section>

  <section class="py-14 md:py-20">
    <div class="page-shell">
      <div class="card-surface overflow-hidden rounded-[2rem] p-8 md:p-12">
        <div class="grid gap-10 md:grid-cols-[1.05fr_0.95fr] md:items-center">
          <div class="space-y-4">
            <p class="eyebrow">Need a cleaner scope?</p>
            <h2 class="max-w-3xl text-4xl tracking-[-0.03em] md:text-5xl">
              The fastest way to start is to send the project type, audience, timeline, and current bottleneck.
            </h2>
            <p class="max-w-2xl text-base text-[var(--muted)] md:text-lg">
              If you already know the kind of content help you need, the next step is simply to connect and outline the brief.
            </p>
          </div>
          <div class="service-mail-cta">
            <MailMotion />
            <a class="button-primary" href={withBase("/contact/")}>Connect with me</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
