---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/content";
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for does not exist on this portfolio site."
>
  <section class="py-24 md:py-32">
    <div class="page-shell">
      <div class="card-surface rounded-[2rem] p-8 md:p-12">
        <p class="eyebrow">404</p>
        <h1 class="mt-3 text-5xl tracking-[-0.04em] md:text-7xl">That page is not here.</h1>
        <p class="mt-4 max-w-2xl text-base text-[var(--muted)] md:text-lg">
          Try the work archive, services page, or contact page instead.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button-primary" href={withBase("/")}>Go home</a>
          <a class="button-secondary" href={withBase("/work/")}>Browse work</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
