---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteData } from "../data/site";
import { withBase } from "../utils/content";

const companyPalette = [
  { base: "#8f4c31", soft: "#bf876b" },
  { base: "#9a5c40", soft: "#c18b71" },
  { base: "#a86b4d", soft: "#cb9a7e" },
  { base: "#7a5d50", soft: "#a88879" },
  { base: "#6c4f43", soft: "#97776a" }
];
---

<BaseLayout
  title="About"
  description="About Atrayee Banerjee: background, editorial experience, industries, tools, and the perspective behind her content strategy work."
  image="/images/deck-media/image11.png"
>
  <section class="py-16 md:py-20">
    <div class="page-shell grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="card-surface overflow-hidden rounded-[2rem]">
        <img src={withBase("/images/deck-media/image11.png")} alt="Atrayee Banerjee outdoors in the mountains" class="h-full w-full object-cover" />
      </div>

      <div class="space-y-5">
        <p class="eyebrow">About</p>
        <h1 class="max-w-4xl text-5xl tracking-[-0.04em] md:text-7xl">Warm, editorial, and strategic by instinct.</h1>
        <div class="space-y-4">
          {siteData.aboutBio.split("\n\n").map((paragraph) => (
            <p class="text-base text-[var(--muted)] md:text-lg">{paragraph}</p>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="button-primary" href={withBase(siteData.resumePath)}>Download resume</a>
          <a class="button-secondary" href={siteData.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="page-shell">
      <div class="about-experience-heading space-y-4">
        <p class="eyebrow">Recent roles and responsibilities</p>
        <h2 class="text-4xl tracking-[-0.03em] md:text-5xl">Experience across in-house strategy, agency execution, and editorial work.</h2>
      </div>

      <div class="about-experience-grid mt-8 md:mt-10">
        {siteData.timeline.map((item, index) => {
          const palette = companyPalette[index % companyPalette.length];

          return (
            <article class="about-experience-card" style={`--experience-base:${palette.base}; --experience-soft:${palette.soft};`}>
              <div class="about-experience-frame"></div>
              <div class="about-experience-panel">
                <div class="about-experience-topline"></div>
                <div class="about-experience-meta">
                  <p class="about-experience-period">{item.period}</p>
                  <p class="about-experience-role">{item.role} | {item.location}</p>
                </div>
                <h3 class="about-experience-company">{item.company}</h3>
                <ul class="about-experience-points">
                  {item.points.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="page-shell grid gap-6 lg:grid-cols-3">
      <article class="card-surface rounded-[1.7rem] p-6">
        <p class="eyebrow">Industries</p>
        <p class="mt-3 text-sm text-[var(--muted)]">
          SaaS, B2B operations, finance, insurance, health, caregiving, beauty, jewelry, migration, travel, marketing, and web growth.
        </p>
      </article>
      <article class="card-surface rounded-[1.7rem] p-6">
        <p class="eyebrow">Tools and process</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {siteData.tools.map((tool) => (
            <span class="pill">{tool}</span>
          ))}
        </div>
      </article>
      <article class="card-surface rounded-[1.7rem] p-6">
        <p class="eyebrow">Education and languages</p>
        <ul class="mt-4 space-y-2 text-sm text-[var(--muted)]">
          {siteData.education.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <p class="mt-4 text-sm text-[var(--muted)]"><strong class="text-[var(--ink)]">Languages:</strong> {siteData.languages.join(", ")}</p>
      </article>
    </div>
  </section>
</BaseLayout>
