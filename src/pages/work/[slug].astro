---
import { getCollection, render } from "astro:content";
import CTASection from "../../components/CTASection.astro";
import WorkCard from "../../components/WorkCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRelatedWork, isVisibleWorkEntry, withBase, workTypeLabels } from "../../utils/content";

export async function getStaticPaths() {
  const workEntries = (await getCollection("work")).filter(isVisibleWorkEntry);
  return workEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allEntries: workEntries }
  }));
}

const { entry, allEntries } = Astro.props;
const { Content } = await render(entry);
const related = getRelatedWork(entry, allEntries);
const metaLine = [entry.data.client, entry.data.publication].filter(Boolean).join(" / ");
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  image={entry.data.coverImage ?? "/og-default.svg"}
  schema={{
    "@context": "https://schema.org",
    "@type": "Article",
    headline: entry.data.title,
    description: entry.data.excerpt,
    author: {
      "@type": "Person",
      name: "Atrayee Banerjee"
    }
  }}
>
  <section class="py-16 md:py-20">
    <div class="page-shell grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
      <div class="space-y-6">
        <a class="button-tertiary" href={withBase("/work/")}>Back to work archive</a>
        <div class="flex flex-wrap gap-2">
          {entry.data.niche.map((tag) => (
            <span class="pill">{tag.replaceAll("-", " ")}</span>
          ))}
        </div>
        <h1 class="max-w-4xl text-5xl tracking-[-0.04em] md:text-7xl">{entry.data.title}</h1>
        <p class="max-w-3xl text-lg text-[var(--muted)]">{entry.data.excerpt}</p>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <div class="card-surface rounded-[1.3rem] p-4">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--accent)]">Format</p>
            <p class="mt-2 text-sm text-[var(--muted)]">{entry.data.format}</p>
          </div>
          <div class="card-surface rounded-[1.3rem] p-4">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--accent)]">Type</p>
            <p class="mt-2 text-sm text-[var(--muted)]">{workTypeLabels[entry.data.workType]}</p>
          </div>
          <div class="card-surface rounded-[1.3rem] p-4">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--accent)]">Client / publication</p>
            <p class="mt-2 text-sm text-[var(--muted)]">{metaLine || "Not specified in source files"}</p>
          </div>
          <div class="card-surface rounded-[1.3rem] p-4">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--accent)]">Access</p>
            <p class="mt-2 text-sm text-[var(--muted)]">{entry.data.proofLabel}</p>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        {entry.data.coverImage ? (
          <div class="card-surface overflow-hidden rounded-[2rem]">
            <img src={withBase(entry.data.coverImage)} alt="" class="w-full object-cover" />
          </div>
        ) : (
          <div class="card-surface rounded-[2rem] p-8">
            <p class="eyebrow">Source note</p>
            <p class="mt-3 text-sm text-[var(--muted)]">
              This entry does not include a supporting screenshot in the uploaded files. The detail page preserves only the information clearly available from the resume and portfolio deck.
            </p>
          </div>
        )}

        <div class="card-surface rounded-[1.6rem] p-6">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--accent)]">Project snapshot</p>
          <dl class="mt-4 space-y-4 text-sm text-[var(--muted)]">
            <div>
              <dt class="font-semibold text-[var(--ink)]">Short summary</dt>
              <dd>{entry.data.summary}</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--ink)]">Objective / brief</dt>
              <dd>{entry.data.objective}</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--ink)]">Approach</dt>
              <dd>{entry.data.approach}</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--ink)]">Writing / strategy angle</dt>
              <dd>{entry.data.angle}</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--ink)]">Deliverable type</dt>
              <dd>{entry.data.deliverableType}</dd>
            </div>
          </dl>

          <div class="mt-6 flex flex-wrap gap-3">
            {entry.data.externalUrl ? (
              <a class="button-primary" href={entry.data.externalUrl} target="_blank" rel="noreferrer">Open source link</a>
            ) : (
              <span class="pill">{entry.data.proofLabel}</span>
            )}
            <a class="button-secondary" href={withBase("/contact/")}>Ask about similar work</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="page-shell">
      <div class="card-surface rounded-[2rem] p-7 md:p-10">
        <div class="rich-copy section-copy">
          <Content />
        </div>
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="pb-16 md:pb-20">
      <div class="page-shell">
        <div class="mb-8">
          <p class="eyebrow">More work like this</p>
          <h2 class="mt-3 text-4xl tracking-[-0.03em] md:text-5xl">Related samples from nearby niches.</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {related.map((relatedEntry) => (
            <WorkCard entry={relatedEntry} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection
    eyebrow="Need a similar engagement?"
    title="If this is close to the kind of content support you need, start with a brief."
    copy="Atrayee can support one-off projects, repeat content production, and strategic refresh work depending on the scope."
    primaryLabel="Get in touch"
    primaryHref={withBase("/contact/")}
    secondaryLabel="Browse services"
    secondaryHref={withBase("/services/")}
  />
</BaseLayout>
